<div class="max-w-md mx-auto bg-white rounded-lg shadow p-6">
  <h1 class="text-xl font-semibold mb-4">Create an Account</h1>

  <% if (typeof errors !== 'undefined' && errors.length) { %>
    <ul class="mb-4 rounded-md bg-rose-100 text-rose-800 px-4 py-3 text-sm list-disc list-inside">
      <% errors.forEach(function(e) { %><li><%= e %></li><% }); %>
    </ul>
  <% } %>

  <form action="/auth/register" method="POST" class="space-y-4">
    <div>
      <label class="block text-sm font-medium mb-1" for="username">Username</label>
      <input type="text" id="username" name="username" value="<%= typeof username !== 'undefined' ? username : '' %>" required
        class="w-full rounded-md border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-500">
    </div>
    <div>
      <label class="block text-sm font-medium mb-1" for="password">Password</label>
      <input type="password" id="password" name="password" required minlength="6"
        class="w-full rounded-md border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-500">
    </div>
    <div>
      <label class="block text-sm font-medium mb-1" for="password2">Confirm Password</label>
      <input type="password" id="password2" name="password2" required minlength="6"
        class="w-full rounded-md border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-teal-500">
    </div>
    <button type="submit"
      class="w-full bg-teal-600 hover:bg-teal-700 text-white font-medium py-2 rounded-md transition">
      Register
    </button>
  </form>
  <p class="text-sm text-slate-500 mt-4">
    Already have an account? <a href="/auth/login" class="text-teal-600 hover:underline">Log in</a>
  </p>
</div>
