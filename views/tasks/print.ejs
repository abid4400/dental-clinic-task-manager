<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/tailwind.css">
  <style>
    @media print {
      .no-print { display: none !important; }
      body { padding: 0 !important; }
      table { page-break-inside: auto; }
      tr { page-break-inside: avoid; page-break-after: auto; }
    }
  </style>
</head>
<body class="bg-white text-slate-800 p-8">

  <div class="no-print mb-6 flex justify-end gap-2">
    <button onclick="window.print()" class="bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium px-4 py-2 rounded-md transition">
      Print / Save as PDF
    </button>
    <button onclick="window.close()" class="border border-slate-300 hover:bg-slate-50 text-slate-700 text-sm font-medium px-4 py-2 rounded-md transition">
      Close
    </button>
  </div>

  <div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-between border-b border-slate-300 pb-4 mb-6">
      <div>
        <h1 class="text-2xl font-bold">Dental Clinic Task Report</h1>
        <p class="text-sm text-slate-500">Generated <%= generatedAt.toLocaleString() %></p>
      </div>
      <div class="text-right text-sm text-slate-500">
        <p>Total tasks: <span class="font-semibold text-slate-700"><%= tasks.length %></span></p>
      </div>
    </div>

    <% if (tasks.length === 0) { %>
      <p class="text-slate-500">No tasks to report.</p>
    <% } else { %>
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b-2 border-slate-300 text-left">
            <th class="py-2 pr-3">Photo</th>
            <th class="py-2 pr-3">Title</th>
            <th class="py-2 pr-3">Patient</th>
            <th class="py-2 pr-3">Doctor</th>
            <th class="py-2 pr-3">Date &amp; Time</th>
            <th class="py-2 pr-3">Status</th>
            <th class="py-2">Notes</th>
          </tr>
        </thead>
        <tbody>
          <% tasks.forEach(function(task) { %>
            <tr class="border-b border-slate-200 align-top">
              <td class="py-2 pr-3">
                <% if (task.photo) { %>
                  <img src="<%= task.photo %>" alt="" class="w-12 h-12 object-cover rounded border border-slate-200">
                <% } else { %>
                  &mdash;
                <% } %>
              </td>
              <td class="py-2 pr-3"><%= task.title %></td>
              <td class="py-2 pr-3"><%= task.patientName %></td>
              <td class="py-2 pr-3"><%= task.doctorName %></td>
              <td class="py-2 pr-3"><%= new Date(task.dateTime).toLocaleString() %></td>
              <td class="py-2 pr-3 capitalize"><%= task.status %></td>
              <td class="py-2 text-slate-500"><%= task.notes || '—' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>

    <p class="text-xs text-slate-400 mt-8 border-t border-slate-200 pt-4">
      Dental Clinic Task Manager &mdash; confidential internal report.
    </p>
  </div>
</body>
</html>
