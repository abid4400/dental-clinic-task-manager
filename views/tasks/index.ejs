<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold">Clinic Tasks &amp; Appointments</h1>
  <a href="/tasks/new" class="bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium px-4 py-2 rounded-md transition">
    + New Task
  </a>
</div>

<% if (tasks.length === 0) { %>
  <div class="bg-white rounded-lg shadow p-8 text-center text-slate-500">
    No tasks yet. Create your first one.
  </div>
<% } else { %>
  <div class="overflow-x-auto bg-white rounded-lg shadow">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-100 text-left">
        <tr>
          <th class="px-4 py-3 font-semibold">Title</th>
          <th class="px-4 py-3 font-semibold">Patient</th>
          <th class="px-4 py-3 font-semibold">Doctor</th>
          <th class="px-4 py-3 font-semibold">Date &amp; Time</th>
          <th class="px-4 py-3 font-semibold">Status</th>
          <th class="px-4 py-3 font-semibold text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% tasks.forEach(function(task) { %>
          <tr>
            <td class="px-4 py-3"><%= task.title %></td>
            <td class="px-4 py-3"><%= task.patientName %></td>
            <td class="px-4 py-3"><%= task.doctorName %></td>
            <td class="px-4 py-3"><%= new Date(task.dateTime).toLocaleString() %></td>
            <td class="px-4 py-3">
              <span class="inline-block px-2 py-1 rounded-full text-xs font-medium
                <%= task.status === 'completed' ? 'bg-emerald-100 text-emerald-700' :
                    task.status === 'cancelled' ? 'bg-rose-100 text-rose-700' :
                    'bg-amber-100 text-amber-700' %>">
                <%= task.status %>
              </span>
            </td>
            <td class="px-4 py-3 text-right space-x-2 whitespace-nowrap">
              <a href="/tasks/<%= task._id %>/edit" class="text-teal-600 hover:underline">Edit</a>
              <form action="/tasks/<%= task._id %>?_method=DELETE" method="POST" class="inline"
                onsubmit="return confirm('Delete this task?');">
                <button type="submit" class="text-rose-600 hover:underline">Delete</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>
